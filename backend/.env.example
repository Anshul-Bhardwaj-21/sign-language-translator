# ── SignBridge Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in values for your environment.

# ── Server ────────────────────────────────────────────────────────────────────
APP_NAME=SignBridge Backend
APP_VERSION=2.0.0
ENVIRONMENT=development
# Use 0.0.0.0 to allow connections from other computers on the same network
HOST=0.0.0.0
PORT=8001
RELOAD=true
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# For LAN demo: add http://<your-ip>:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Sign Language Model ───────────────────────────────────────────────────────
# Options: heuristic | local | cloud
MODEL_ENGINE=heuristic

# Set to 1 to force heuristic fallback regardless of MODEL_ENGINE
# Use this when model weights are not yet trained
USE_FALLBACK_SIGN_MODEL=1

# Path to trained model directory (used when MODEL_ENGINE=local)
SIGN_MODEL_PATH=../models/sign_model.pt
LOCAL_MODEL_DIR=backend/artifacts/models/local_sign_model
MEDIAPIPE_TASK_PATH=backend/resources/mediapipe/hand_landmarker.task

# ── Cloud inference (optional) ────────────────────────────────────────────────
CLOUD_PROVIDER=disabled
CLOUD_API_KEY=

# ── WebRTC ICE servers ────────────────────────────────────────────────────────
STUN_SERVER=stun:stun.l.google.com:19302
# TURN is required for connections across different networks (not same LAN)
# Leave blank for local/LAN demo
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# ── Room settings ─────────────────────────────────────────────────────────────
DEFAULT_ROOM_CAPACITY=2
MAX_ROOM_CAPACITY=6
RECONNECT_GRACE_SECONDS=20

# ── Inference thresholds ──────────────────────────────────────────────────────
ENABLE_MEDIAPIPE=true
FRAME_BLUR_THRESHOLD=80.0
FRAME_LUMINANCE_THRESHOLD=32.0
HAND_CONFIDENCE_THRESHOLD=0.6
