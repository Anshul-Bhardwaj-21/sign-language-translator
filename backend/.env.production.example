# ── Production environment template ──────────────────────────────────────────
# Copy to .env on your server (Railway / Render / VPS) and fill in values.

APP_NAME=SignBridge Backend
APP_VERSION=2.0.0
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8001
RELOAD=false
LOG_LEVEL=INFO

# Your deployed frontend URL (Netlify domain)
FRONTEND_URL=https://your-app.netlify.app

# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-app.netlify.app

# ── Model engine ──────────────────────────────────────────────────────────────
# Options: heuristic | local | cloud
# Use "local" after model training is complete
MODEL_ENGINE=local

# Path to your trained model directory (relative to repo root)
LOCAL_MODEL_DIR=backend/artifacts/models/local_sign_model

# MediaPipe hand landmarker task file
MEDIAPIPE_TASK_PATH=backend/resources/mediapipe/hand_landmarker.task

# ── Cloud fallback (optional) ─────────────────────────────────────────────────
CLOUD_PROVIDER=disabled
CLOUD_API_KEY=

# ── Room settings ─────────────────────────────────────────────────────────────
DEFAULT_ROOM_CAPACITY=2
MAX_ROOM_CAPACITY=6
RECONNECT_GRACE_SECONDS=20

# ── Inference thresholds ──────────────────────────────────────────────────────
ENABLE_MEDIAPIPE=true
FRAME_BLUR_THRESHOLD=80.0
FRAME_LUMINANCE_THRESHOLD=32.0
HAND_CONFIDENCE_THRESHOLD=0.6
