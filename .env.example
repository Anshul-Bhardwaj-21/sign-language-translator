# =============================================================================
# ADVANCED MEETING FEATURES - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://meeting_user:meeting_pass@localhost:5432/meeting_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Redis connection settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Legacy URL format (alternative to individual settings)
REDIS_URL=redis://localhost:6379

# Redis usage settings
REDIS_SESSION_TTL_SECONDS=3600          # 1 hour
REDIS_FRAME_BUFFER_MAX_SIZE=60          # 60 frames (2 seconds at 30fps)
REDIS_FRAME_BUFFER_IDLE_TIMEOUT=600     # 10 minutes
REDIS_MEETING_PARTICIPANTS_TTL=86400    # 24 hours

# =============================================================================
# BACKEND SERVER CONFIGURATION
# =============================================================================
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_USE_MOCK_MODEL=1
FEATURE_ENABLE_TTS=1
FEATURE_ENABLE_RECORDING=1
FEATURE_ENABLE_TRANSCRIPTION=1
FEATURE_ENABLE_AI_SUMMARY=1
FEATURE_ENABLE_SIGN_LANGUAGE=1
FEATURE_ENABLE_CAPTIONS=1
FEATURE_ENABLE_BREAKOUT_ROOMS=0
FEATURE_ENABLE_WAITING_ROOM=1

# =============================================================================
# WEBRTC CONFIGURATION
# =============================================================================
# STUN/TURN servers for WebRTC
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=

# =============================================================================
# CLOUD STORAGE CONFIGURATION
# =============================================================================
# Choose: s3, gcs, or local
STORAGE_PROVIDER=local
STORAGE_BUCKET_NAME=meeting-recordings

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google Cloud Storage Configuration
GCS_PROJECT_ID=
GCS_CREDENTIALS_PATH=

# Local storage path (for development)
LOCAL_STORAGE_PATH=./storage

# =============================================================================
# ML MODEL CONFIGURATION
# =============================================================================
# Model Registry
MODEL_REGISTRY_PATH=./models
MODEL_REGISTRY_BACKEND=local  # local, s3, gcs

# Inference Configuration
INFERENCE_DEVICE=cpu  # cpu or cuda
INFERENCE_BATCH_SIZE=1
INFERENCE_CONFIDENCE_THRESHOLD=0.7
INFERENCE_MAX_QUEUE_SIZE=100

# Sign Language Recognition
SIGN_LANGUAGE_MODEL_VERSION=latest
SIGN_LANGUAGE_VOCABULARY_SIZE=50
SIGN_LANGUAGE_FRAME_BUFFER_SIZE=60
SIGN_LANGUAGE_INFERENCE_INTERVAL_MS=500

# =============================================================================
# MLFLOW CONFIGURATION
# =============================================================================
# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://meeting_user:meeting_pass@localhost:5432/meeting_db
MLFLOW_ARTIFACT_ROOT=./backend/storage/mlflow-artifacts

# MLflow Experiments
MLFLOW_EXPERIMENT_NAME=sign-language-asl-baseline

# MLflow Model Registry
MLFLOW_REGISTERED_MODEL_NAME=sign-language-asl

# MLflow Server Settings
MLFLOW_HOST=0.0.0.0
MLFLOW_PORT=5000
MLFLOW_WORKERS=2

# Cloud Artifact Store (Optional - for production)
# AWS S3: s3://bucket-name/mlflow-artifacts
# GCS: gs://bucket-name/mlflow-artifacts
# MLFLOW_ARTIFACT_ROOT=s3://my-bucket/mlflow-artifacts

# =============================================================================
# TRANSCRIPTION SERVICE CONFIGURATION
# =============================================================================
# Choose: whisper, google, aws, azure
TRANSCRIPTION_PROVIDER=whisper
TRANSCRIPTION_LANGUAGE=en
TRANSCRIPTION_MODEL=base  # tiny, base, small, medium, large

# Google Speech-to-Text
GOOGLE_SPEECH_API_KEY=

# AWS Transcribe
AWS_TRANSCRIBE_REGION=us-east-1

# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# =============================================================================
# AI SUMMARY SERVICE CONFIGURATION
# =============================================================================
# Choose: openai, anthropic, local
AI_SUMMARY_PROVIDER=openai
AI_SUMMARY_MODEL=gpt-4
AI_SUMMARY_MAX_TOKENS=500

# OpenAI Configuration
OPENAI_API_KEY=

# Anthropic Configuration
ANTHROPIC_API_KEY=

# =============================================================================
# CALENDAR INTEGRATION
# =============================================================================
# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8001/auth/google/callback

# Microsoft Outlook
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8001/auth/microsoft/callback

# =============================================================================
# EMAIL INTEGRATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Drift Detection
DRIFT_DETECTION_ENABLED=1
DRIFT_DETECTION_INTERVAL_HOURS=1
DRIFT_DETECTION_KL_THRESHOLD=0.1
DRIFT_DETECTION_SAMPLE_SIZE=100

# Analytics
ANALYTICS_ENABLED=1
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL_SECONDS=60

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=1
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# =============================================================================
# MEETING CONFIGURATION
# =============================================================================
MAX_PARTICIPANTS_PER_MEETING=100
MAX_CONCURRENT_MEETINGS=100
MAX_MEETING_DURATION_HOURS=24
MAX_RECORDING_SIZE_GB=10
MAX_BREAKOUT_ROOMS=20

# =============================================================================
# VIDEO QUALITY CONFIGURATION
# =============================================================================
DEFAULT_VIDEO_RESOLUTION=720p  # 720p or 1080p
DEFAULT_VIDEO_FPS=30
DEFAULT_AUDIO_BITRATE=128
VIDEO_QUALITY_ADAPTATION_ENABLED=1

# =============================================================================
# FIREBASE CONFIGURATION (Optional)
# =============================================================================
FIREBASE_CREDENTIALS_PATH=
FIREBASE_DATABASE_URL=

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
DEBUG=0
RELOAD=1
WORKERS=1
