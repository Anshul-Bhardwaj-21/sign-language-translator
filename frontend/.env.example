# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_MOCK_MODE=true
VITE_ENABLE_SIGN_LANGUAGE=true
VITE_ENABLE_CAPTIONS=true
VITE_ENABLE_RECORDING=true
VITE_ENABLE_SCREEN_SHARING=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_WHITEBOARD=true
VITE_ENABLE_POLLS=true
VITE_ENABLE_BREAKOUT_ROOMS=false
VITE_ENABLE_WAITING_ROOM=true

# =============================================================================
# WEBRTC CONFIGURATION
# =============================================================================
VITE_STUN_SERVER_URL=stun:stun.l.google.com:19302
VITE_TURN_SERVER_URL=
VITE_TURN_SERVER_USERNAME=
VITE_TURN_SERVER_CREDENTIAL=

# =============================================================================
# VIDEO CONFIGURATION
# =============================================================================
VITE_DEFAULT_VIDEO_RESOLUTION=720p
VITE_DEFAULT_VIDEO_FPS=30
VITE_MAX_VIDEO_BITRATE=2500
VITE_MIN_VIDEO_BITRATE=150

# =============================================================================
# SIGN LANGUAGE CONFIGURATION
# =============================================================================
VITE_SIGN_LANGUAGE_ENABLED=true
VITE_SIGN_LANGUAGE_FRAME_RATE=30
VITE_SIGN_LANGUAGE_BUFFER_SIZE=60
VITE_SIGN_LANGUAGE_INFERENCE_INTERVAL=500
VITE_SIGN_LANGUAGE_CONFIDENCE_THRESHOLD=0.7

# =============================================================================
# UI CONFIGURATION
# =============================================================================
VITE_DEFAULT_LAYOUT=grid
VITE_MAX_PARTICIPANTS_DISPLAY=25
VITE_ENABLE_REACTIONS=true
VITE_ENABLE_HAND_RAISE=true

# =============================================================================
# FIREBASE CONFIGURATION (Optional)
# =============================================================================
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_TRACKING_ID=

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
VITE_DEBUG=false
VITE_LOG_LEVEL=info
