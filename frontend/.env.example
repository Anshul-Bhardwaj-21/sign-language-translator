# ── SignBridge Frontend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in values.

# Backend HTTP base URL
# For LAN demo: replace localhost with your machine's local IP (e.g. 192.168.1.10)
VITE_API_URL=http://localhost:8001

# Backend WebSocket base URL (same host, ws:// protocol)
VITE_WS_URL=ws://localhost:8001

# Optional: default room code prefix shown in dashboard
VITE_DEFAULT_ROOM_PREFIX=SB
